  "docs": [
    {
      "id": "agent-feedback-loop",
      "title": "Agent Feedback Loop for Knowledge Classification",
      "summary": "Notes on rule-first categorization and human correction loops.",
      "tags": [
        "assistant",
        "classification",
        "model"
      ],
      "categoryHint": "ai",
      "createdAt": "2026-02-12T10:00:00.000Z",
      "updatedAt": "2026-02-27T18:04:00.000Z",
      "body": "Start with deterministic rules and track confidence.\nAllow fast correction actions so recategorization can be triggered after edits.\nPersist reasons to make category decisions explainable.",
      "status": "active"
    },
    {
      "id": "content-taxonomy-seed",
      "title": "Content Taxonomy Seed",
      "summary": "Initial root categories for the virtual librarian.",
      "tags": [
        "pm",
        "strategy",
        "user"
      ],
      "createdAt": "2026-02-11T11:20:00.000Z",
      "updatedAt": "2026-02-26T11:20:00.000Z",
      "body": "Categories are broad at first and become deeper only when retrieval friction appears.\nTrack uncategorized volume as an operational metric.\nAdd lane growth threshold based on content count.",
      "status": "active"
    },
    {
      "id": "engine-room-layout",
      "title": "Engine Room Layout Principles",
      "summary": "A practical baseline for a modular room-first 3D engine layout.",
      "tags": [
        "engine",
        "architecture",
        "code"
      ],
      "categoryHint": "engineering",
      "createdAt": "2026-02-10T09:00:00.000Z",
      "updatedAt": "2026-02-28T12:10:00.000Z",
      "body": "Use route as the source of active space identity.\nKeep systems independent: interaction, world profile, and player physics.\nPrefer simple authored modules over procedural complexity for early production.",
      "status": "active"
    },
    {
      "id": "library-navigation-copy",
      "title": "Library Navigation Copy Draft",
      "summary": "UX copy options for prompts, controls, and interaction hints.",
      "tags": [
        "ux",
        "writing",
        "doc"
      ],
      "categoryHint": "writing",
      "createdAt": "2026-02-13T08:30:00.000Z",
      "updatedAt": "2026-02-25T07:40:00.000Z",
      "body": "Short labels reduce cognitive load in 3D scenes.\nPrompts should be verb-first and action-specific.\nAvoid modal overload by preserving one primary panel context.",
      "status": "active"
    },
    {
      "id": "notes-raw-dump",
      "title": "Raw Dump: Misc Notes",
      "summary": "Temporary loose notes without clear category ownership.",
