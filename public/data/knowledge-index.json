      "body": "This file intentionally contains mixed concepts.\nIt should normally fall into uncategorized when no stronger signal appears.",
      "status": "active"
    },
    {
      "id": "personal-weekly-review",
      "title": "Weekly Review Template",
      "summary": "A personal reflection template used to inspect pace and focus.",
      "tags": [
        "journal",
        "habit",
        "life"
      ],
      "categoryHint": "personal",
      "createdAt": "2026-02-08T21:00:00.000Z",
      "updatedAt": "2026-02-22T21:00:00.000Z",
      "body": "Highlight wins, misses, and corrective actions.\nDefine one focus theme for next week.\nArchive completed loops and keep open loops visible.",
      "status": "active"
    },
    {
      "id": "release-checklist-v1",
      "title": "Release Checklist v1",
      "summary": "Stability checks for interaction and route-space transitions.",
      "tags": [
        "qa",
        "doc",
        "pm"
      ],
      "createdAt": "2026-02-16T07:45:00.000Z",
      "updatedAt": "2026-02-21T09:45:00.000Z",
      "body": "Verify prompt visibility and E interaction in all spaces.\nConfirm build and dev commands before merging.\nTrack regression notes per route.",
      "status": "active"
    },
    {
      "id": "search-facet-decisions",
      "title": "Search Facet Decisions",
      "summary": "Why client fulltext plus facet filters is enough for v1.",
      "tags": [
        "search",
        "architecture",
        "ux"
      ],
      "categoryHint": "engineering",
      "createdAt": "2026-02-15T06:10:00.000Z",
      "updatedAt": "2026-02-23T12:30:00.000Z",
      "body": "Token search by title, summary, tags, and body supports most retrieval tasks.\nFacet by category reduces mismatch and improves discoverability.\nSemantic search can be introduced when corpus size grows.",
      "status": "active"
    },
    {
      "id": "visual-reference-audit",
      "title": "Visual Reference Audit for Library Space",
      "summary": "Color and structure notes inspired by industrial libraries.",
      "tags": [
        "visual",
        "ui",
        "layout"
      ],
      "categoryHint": "design",
      "createdAt": "2026-02-14T05:10:00.000Z",
      "updatedAt": "2026-02-24T10:25:00.000Z",
      "body": "Use steel blue and graphite tones for calm high-density spaces.\nMaintain a clear center aisle and rhythm with repeated bays.\nPlace bright accents only on interactable targets.",
      "status": "active"
    }
